# === Required ===

# Google AI Studio API key — powers both Gemini Live dialogue AND conversation evaluation
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Chivox MCP API key — powers pronunciation scoring
# Get yours at: https://mcp-global.cloud.chivox.com
CHIVOX_MCP_API_KEY=your_chivox_api_key_here

# === Optional (Evaluation LLM) ===
# By default, conversation evaluation uses Gemini 3.1 Flash Lite (free tier) via your Google API key.
# To use a different LLM (GLM, DeepSeek, etc.), set these:

# LLM_BASE_URL=https://api.example.com/v1
# LLM_API_KEY=your_llm_api_key_here
# LLM_MODEL=your-model-name
